{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/data/**",
              "ui_kits/blueprint/**",
              "ui_kits/newsletter/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fragment Mono))/i]",
        "message": "Font not provided by the design system. Available: Fragment Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Annotation'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|side|color|children|key|ref|className|style|children)$/]",
        "message": "<Annotation> doesn't accept that prop. Declared props: label, side, color, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Annotation'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:left|right|top|bottom)$/]",
        "message": "<Annotation> side must be one of 'left' | 'right' | 'top' | 'bottom'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|gold|positive|negative)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'gold' | 'positive' | 'negative'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BarDatum'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|highlight|key|ref|className|style|children)$/]",
        "message": "<BarDatum> doesn't accept that prop. Declared props: label, value, highlight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|fullWidth|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, fullWidth, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|kicker|sheet|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: as, kicker, sheet, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CitationChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:source|date|estimate|onInk|key|ref|className|style|children)$/]",
        "message": "<CitationChip> doesn't accept that prop. Declared props: source, date, estimate, onInk."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|align|numeric|key|ref|className|style|children)$/]",
        "message": "<DataColumn> doesn't accept that prop. Declared props: key, label, align, numeric."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<DataColumn> align must be one of 'left' | 'right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GapFigure'] > JSXAttribute > JSXIdentifier[name!=/^(?:from|to|label|onInk|size|key|ref|className|style|children)$/]",
        "message": "<GapFigure> doesn't accept that prop. Declared props: from, to, label, onInk, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='GapFigure'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<GapFigure> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:mono|invalid|size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: mono, invalid, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Schematic'] > JSXAttribute > JSXIdentifier[name!=/^(?:sheet|total|title|running|bracket|source|footer|width|children|key|ref|className|style|children)$/]",
        "message": "<Schematic> doesn't accept that prop. Declared props: sheet, total, title, running, bracket, source, footer, width, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SchematicNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:step|name|figure|unit|status|highlight|key|ref|className|style|children)$/]",
        "message": "<SchematicNode> doesn't accept that prop. Declared props: step, name, figure, unit, status, highlight."
      },
      {
        "selector": "JSXOpeningElement[name.name='SheetHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:sheet|total|title|subtitle|onInk|key|ref|className|style|children)$/]",
        "message": "<SheetHeader> doesn't accept that prop. Declared props: sheet, total, title, subtitle, onInk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|prefix|label|delta|deltaDirection|emphasis|size|onInk|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, unit, prefix, label, delta, deltaDirection, emphasis, size, onInk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='deltaDirection'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<Stat> deltaDirection must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='emphasis'] > Literal[value!=/^(?:default|gold|accent)$/]",
        "message": "<Stat> emphasis must be one of 'default' | 'gold' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Stat> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TitleBlockField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<TitleBlockField> doesn't accept that prop. Declared props: label, value."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
